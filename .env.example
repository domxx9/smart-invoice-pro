# ─── Core ───────────────────────────────────────────────────────────────────────

# Paperclip API base URL for feedback submission
VITE_PAPERCLIP_URL=http://localhost:3100

# Paperclip URL for server-side API routes (e.g., error-report.js)
PAPERCLIP_URL=http://localhost:3100

# ─── Commerce Integrations ─────────────────────────────────────────────────────

# Squarespace Commerce API bearer token
# (Store in Capacitor Secure Storage at runtime — never commit real keys)
VITE_SQUARESPACE_API_KEY=

# Shopify per-store access token (X-Shopify-Access-Token)
# Same rule as Squarespace — Capacitor Secure Storage at runtime
VITE_SHOPIFY_ACCESS_TOKEN=

# ─── AI / Model Downloads ──────────────────────────────────────────────────────

# HuggingFace API token for downloading gated Gemma/Llama models
# Not required for public models (nano, small, embedder)
VITE_HUGGINGFACE_TOKEN=